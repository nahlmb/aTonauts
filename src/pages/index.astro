---
import BookLayout from '../layouts/BookLayout.astro';
---

<BookLayout title="ATonauts Misi 1.0">
  <main class="cover-page" id="cover">
    <img
      src="/assets/images/00_Cover.png"
      alt="Cover ATonauts Misi 1.0 — Menjawab Panggilan Bumi melalui Baterai Ponselmu"
      class="cover-image"
    />

    <div class="cover-hint" aria-hidden="true">
      <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="9 18 15 12 9 6"/>
      </svg>
    </div>
  </main>
</BookLayout>

<script>
  const cover = document.getElementById('cover')!;
  let startX = 0;

  cover.addEventListener('touchstart', (e) => {
    startX = e.touches[0].clientX;
  }, { passive: true });

  cover.addEventListener('touchend', (e) => {
    const dx = e.changedTouches[0].clientX - startX;
    if (dx < -40) goNext();
  }, { passive: true });

  cover.addEventListener('click', goNext);

  function goNext() {
    window.location.href = '/prolog';
  }
</script>

<style>
  .cover-page {
    position: relative;
    width: 100%;
    height: 100%;
    overflow: hidden;
    cursor: pointer;
    user-select: none;
  }

  .cover-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    display: block;
  }

  .cover-hint {
    position: absolute;
    right: 20px;
    top: 50%;
    transform: translateY(-50%);
    color: #3CE2FF;
    animation: arrow-hint 1.4s ease-in-out infinite;
    filter: drop-shadow(0 0 8px #3CE2FF);
  }
</style>
