---
import BookLayout from '../layouts/BookLayout.astro';
import SubmitFinalResponses from '../components/islands/SubmitFinalResponses.jsx';
---

<BookLayout title="Misi Selesai — ATonauts">
  <main class="done-page">
    <div class="done-content">
      <div class="done-icon" aria-hidden="true">
        <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="#3CE2FF" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
      </div>

      <h1 class="done-title">MISI SELESAI</h1>
      <p class="done-subtitle">Misi 1.0 — ATonauts</p>

      <p class="done-body">
        Kamu telah menyelesaikan enam tahap penyelidikan sebagai Philaerners.
        Temuan, pertanyaan, dugaan, hasil eksperimen, dan refleksimu sedang direkap.
      </p>

      <SubmitFinalResponses client:load />

      <p class="done-tagline">
        <em>Jangan Percaya. Selidiki. Dan Buktikan.</em>
      </p>

      <a href="/" class="btn done-btn">KEMBALI KE AWAL</a>
    </div>
  </main>
</BookLayout>

<style>
  .done-page {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 32px 24px;
    min-height: 0;
    overflow: hidden;
  }

  .done-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 20px;
    text-align: center;
    animation: fade-in 0.5s ease;
  }

  .done-icon {
    filter: drop-shadow(0 0 20px rgba(60, 226, 255, 0.5));
  }

  .done-title {
    font-family: var(--font-heading);
    font-size: 36px;
    color: var(--cyan);
    letter-spacing: 0.06em;
  }

  .done-subtitle {
    font-family: var(--font-caption);
    font-size: 13px;
    color: rgba(245, 247, 250, 0.5);
    margin-top: -12px;
  }

  .done-body {
    font-size: 14px;
    color: rgba(245, 247, 250, 0.75);
    line-height: 1.7;
    max-width: 300px;
  }

  .done-tagline {
    font-size: 14px;
    color: var(--light);
  }

  :global(.submit-status) {
    font-family: var(--font-tag);
    font-size: 10px;
    letter-spacing: 0.06em;
    color: var(--cyan);
    text-transform: uppercase;
  }

  :global(.submit-status-failed) {
    color: var(--orange);
    max-width: 320px;
    line-height: 1.5;
  }

  .done-btn {
    margin-top: 12px;
    padding: 12px 28px;
    background: transparent;
    color: var(--orange);
    border: 1px solid var(--orange);
    border-radius: 6px;
    font-family: var(--font-tag);
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    text-decoration: none;
    animation: glow-pulse 2s ease-in-out infinite;
  }
</style>
