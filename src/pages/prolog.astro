---
import BookLayout from '../layouts/BookLayout.astro';
import VideoPlayer from '../components/islands/VideoPlayer.jsx';
import PrologController from '../components/islands/PrologController.jsx';
---

<BookLayout title="Prolog — ATonauts">
  <main class="prolog-page">

    <header class="prolog-header">
      <h1 class="prolog-title">PROLOG</h1>
      <p class="prolog-subtitle">Mengapa Misi Ini Hadir?</p>
    </header>

    <section class="prolog-video">
      <VideoPlayer client:load src="/assets/video/prolog_intro.mp4" />
    </section>

    <section class="prolog-team">
      <p class="team-label">Diinisiasi Oleh — <strong>Philaerners-Squad</strong></p>
      <p class="team-desc">Tim Pengembang Misi</p>
      <div class="team-cards">
        <article class="team-card">
          <img src="/assets/images/foto_tim_1.png" alt="Nailah Tharik Baeshin" class="team-photo" />
          <div class="team-info">
            <p class="team-name">NAILAH THARIK BAESHIN</p>
            <p class="team-role">Lead Researcher &amp; Developer</p>
          </div>
        </article>
        <article class="team-card">
          <img src="/assets/images/foto_tim_2.jpg" alt="Achmad Ridwan" class="team-photo" />
          <div class="team-info">
            <p class="team-name">ACHMAD RIDWAN</p>
            <p class="team-role">Design &amp; Curriculum</p>
          </div>
        </article>
        <article class="team-card">
          <img src="/assets/images/foto_tim_3.jpg" alt="Hanhan Dianhar" class="team-photo" />
          <div class="team-info">
            <p class="team-name">HANHAN DIANHAR</p>
            <p class="team-role">Science Content Expert</p>
          </div>
        </article>
      </div>
    </section>

  </main>

  <PrologController client:load />
</BookLayout>

<style>
  .prolog-page {
    flex: 1;
    display: flex;
    flex-direction: column;
    padding: 16px 16px 80px;
    gap: 14px;
    min-height: 0;
    overflow: hidden;
  }

  /* Header */
  .prolog-header {
    flex-shrink: 0;
    text-align: center;
  }

  .prolog-title {
    font-family: var(--font-heading);
    font-size: 28px;
    color: var(--cyan);
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .prolog-subtitle {
    font-style: italic;
    font-size: 13px;
    color: var(--cyan);
    margin-top: 2px;
    opacity: 0.8;
  }

  /* Video */
  .prolog-video {
    flex-shrink: 0;
  }

  /* Team */
  .prolog-team {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 3px;
    min-height: 0;
    margin-left: -16px;
    margin-right: -16px;
  }

  .team-label {
    font-style: italic;
    font-size: 12px;
    color: var(--cyan);
    flex-shrink: 0;
    padding-left: 16px;
  }

  .team-label strong {
    font-style: normal;
    font-weight: 400;
  }

  .team-desc {
    font-style: italic;
    font-size: 10px;
    color: rgba(245, 247, 250, 0.45);
    flex-shrink: 0;
    padding-left: 16px;
  }

  .team-cards {
    flex: 1;
    display: flex;
    gap: 4px;
    margin-top: 8px;
    min-height: 0;
  }

  .team-card {
    flex: 1;
    min-width: 0;
    border: 1px solid rgba(245, 247, 250, 0.18);
    border-radius: 0;
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }

  .team-card:first-child {
    border-left: none;
  }

  .team-card:last-child {
    border-right: none;
  }

  .team-photo {
    width: 100%;
    flex: 1;
    min-height: 0;
    object-fit: cover;
    object-position: top;
    display: block;
  }

  .team-info {
    padding: 6px 4px 8px;
    flex-shrink: 0;
    background: rgba(0, 0, 0, 0.2);
  }

  .team-name {
    font-family: var(--font-tag);
    font-size: 7px;
    color: var(--light);
    text-align: center;
    line-height: 1.35;
    letter-spacing: 0.02em;
  }

  .team-role {
    font-style: italic;
    font-size: 8.5px;
    color: rgba(245, 247, 250, 0.5);
    text-align: center;
    margin-top: 2px;
    line-height: 1.3;
  }
</style>
