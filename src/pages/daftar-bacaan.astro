<BookLayout title="Daftar Bacaan — ATonauts">
  <main class="reader-page">
    <header><p class="section-kicker">SUMBER PENYELIDIKAN</p><h1>DAFTAR BACAAN</h1><p>Gunakan sumber berikut untuk memeriksa kembali klaim dalam misi.</p></header>
    <ol class="reference-list">
      {references.map(([citation, url]) => <li>{citation} {url && <a href={url} target="_blank" rel="noreferrer">Buka DOI ↗</a>}</li>)}
    </ol>
    <div class="page-actions">
      <a href="/kamus" class="btn btn-orange">KEMBALI</a>
      <a href="/selesai" class="btn btn-nav">TUNTASKAN MISI</a>
    </div>
  </main>
</BookLayout>

<style>
  .reader-page { flex: 1; overflow-y: auto; padding: 24px 14px; display: grid; gap: 16px; }
  header h1 { color: var(--cyan); font-size: 30px; }
  header p:last-child { color: rgba(245,247,250,.5); font-size: 12px; }
</style>
